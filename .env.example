# ============================================================
# Exact file location: .env.example
# Horseshoe Tavern AI
# Phase 1 Part 1.24
#
# SAFE ENVIRONMENT VARIABLE TEMPLATE
#
# Copy this file locally:
#
#   Copy-Item .env.example .env
#
# Then replace development placeholders only inside .env.
#
# Never commit:
#   .env
#   production database credentials
#   secret keys
#   signing keys
#   API credentials
#   customer personal information
# ============================================================


# ============================================================
# SECTION 01 - APPLICATION IDENTITY
# ============================================================

APP_NAME=Horseshoe Tavern AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

DEFAULT_BUSINESS_SLUG=horseshoe-tavern
BUSINESS_DISPLAY_NAME=Horseshoe Tavern


# ============================================================
# SECTION 02 - LOCAL SERVER
# ============================================================

HOST=0.0.0.0
PORT=8000
RELOAD=true

PUBLIC_BASE_URL=http://127.0.0.1:8000
API_BASE_PATH=/api/chat


# ============================================================
# SECTION 03 - DATABASE
# ============================================================

# Local SQLite default:
DATABASE_URL=sqlite:///./horseshoe_tavern_ai.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://username:password@hostname:5432/horseshoe_tavern_ai

INITIALIZE_DATABASE_ON_STARTUP=true
DATABASE_ECHO=false

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=300

DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_SECONDS=30

DATABASE_HEALTH_CHECK_ENABLED=true
DATABASE_HEALTH_CHECK_QUERY=SELECT 1


# ============================================================
# SECTION 04 - APPLICATION SECRETS
# ============================================================

# Replace these in the local .env file.
# Render generates production values automatically.

SECRET_KEY=replace-with-a-long-random-development-secret
SESSION_SIGNING_KEY=replace-with-a-different-long-random-development-secret

SECRET_KEY_MINIMUM_LENGTH=32
SESSION_COOKIE_NAME=horseshoe_tavern_ai_session

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax


# ============================================================
# SECTION 05 - WEBSITE AND WIDGET
# ============================================================

OFFICIAL_WEBSITE_URL=https://www.thehorseshoetavern.com/
WIDGET_SCRIPT_PATH=/static/widget/horseshoe-widget.js
WIDGET_STYLESHEET_PATH=/static/widget/horseshoe-widget.css
WIDGET_PREVIEW_PATH=/static/widget/widget-preview.html

DEFAULT_WIDGET_STATE=collapsed
DEFAULT_WIDGET_SIZE=compact

WIDGET_RESTORE_ENABLED=true
WIDGET_STATE_PERSISTENCE_ENABLED=true
WIDGET_LOCAL_STORAGE_ENABLED=true
WIDGET_SERVER_STORAGE_ENABLED=true

WIDGET_REQUEST_TIMEOUT_SECONDS=30
WIDGET_MAXIMUM_RETRY_ATTEMPTS=3
WIDGET_RETRY_BASE_DELAY_MILLISECONDS=500


# ============================================================
# SECTION 06 - CORS AND TRUSTED HOSTS
# ============================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000,https://www.thehorseshoetavern.com,https://thehorseshoetavern.com

ALLOWED_HOSTS=localhost,127.0.0.1,www.thehorseshoetavern.com,thehorseshoetavern.com

CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=600


# ============================================================
# SECTION 07 - CHAT LIMITS
# ============================================================

MAXIMUM_MESSAGE_CHARACTERS=3000
MAXIMUM_RESPONSE_CHARACTERS=12000

MAXIMUM_RESTORE_MESSAGES=100
MAXIMUM_CONVERSATION_MESSAGES=500
MAXIMUM_CONVERSATION_METADATA_BYTES=50000

MAXIMUM_SOURCE_COUNT=12
MAXIMUM_RESPONSE_ACTION_COUNT=8
MAXIMUM_ENTITY_COUNT=64

CHAT_REQUEST_TIMEOUT_SECONDS=45
CHAT_TRANSACTION_TIMEOUT_SECONDS=60


# ============================================================
# SECTION 08 - CONVERSATION CONTEXT
# ============================================================

CONTEXT_TTL_MINUTES=45
CONTEXT_MAXIMUM_RECENT_TURNS=12
CONTEXT_MAXIMUM_ENTITY_HISTORY=50
CONTEXT_MAXIMUM_PAGE_HISTORY=10

CONVERSATION_RESTORE_ENABLED=true
CONVERSATION_SUMMARY_ENABLED=true

PREVIOUS_INTENT_LOCK_ALLOWED=false
EXPLICIT_CONTEXT_OVERRIDE_ENABLED=true
CONTROLLED_PRONOUN_RESOLUTION_ENABLED=true


# ============================================================
# SECTION 09 - NLU
# ============================================================

NLU_ENABLED=true
NLU_MINIMUM_CONFIDENCE=0.44
NLU_HIGH_CONFIDENCE_THRESHOLD=0.80
NLU_AMBIGUITY_MARGIN=0.10
NLU_MULTI_INTENT_THRESHOLD=0.58

SPELLING_CORRECTION_ENABLED=true
SPELLING_MINIMUM_CONFIDENCE=0.72
SPELLING_DATABASE_MAPPINGS_ENABLED=true
SPELLING_UNVERIFIED_OBSERVATION_ENABLED=true

ENTITY_EXTRACTION_ENABLED=true
PAGE_CONTEXT_WEIGHT=0.08
CONVERSATION_CONTEXT_WEIGHT=0.12


# ============================================================
# SECTION 10 - VERIFIED KNOWLEDGE
# ============================================================

KNOWLEDGE_RETRIEVAL_ENABLED=true
KNOWLEDGE_STALE_AFTER_DAYS=45
KNOWLEDGE_DEFAULT_RESULT_LIMIT=12
KNOWLEDGE_MINIMUM_RELEVANCE=0.20

VERIFIED_KNOWLEDGE_ONLY=true
REQUIRE_SOURCE_ATTRIBUTION=true
ALLOW_STALE_VERIFIED_KNOWLEDGE=true

AUTOMATIC_KNOWLEDGE_PROMOTION=false
PUBLIC_INPUT_CAN_UPDATE_VERIFIED_FACTS=false
FEEDBACK_CAN_UPDATE_VERIFIED_FACTS=false

KNOWLEDGE_REVIEW_REQUIRED=true
KNOWLEDGE_ROLLBACK_ENABLED=true
KNOWLEDGE_POISONING_DETECTION_ENABLED=true


# ============================================================
# SECTION 11 - RESPONSE SAFETY
# ============================================================

GROUNDED_RESPONSES_ONLY=true
HALLUCINATION_GUARD_ENABLED=true
UNSUPPORTED_CLAIM_LIMIT=0

ALLERGEN_CONFIRMATION_WARNING_ENABLED=true
RESERVATION_AVAILABILITY_WARNING_ENABLED=true
PRIVATE_EVENT_AVAILABILITY_WARNING_ENABLED=true
STALE_SOURCE_WARNING_ENABLED=true

SAFE_FALLBACK_ENABLED=true
SAFE_ERROR_DETAILS_ENABLED=false


# ============================================================
# SECTION 12 - PRIVACY AND DATA PROTECTION
# ============================================================

PII_REDACTION_ENABLED=true
PII_REDACTION_TOKEN=[REDACTED]

STORE_RAW_USER_MESSAGES=true
STORE_NORMALIZED_MESSAGES=true
STORE_CORRECTED_MESSAGES=true

STORE_PASSWORDS=false
STORE_PAYMENT_CARD_DATA=false
STORE_SECURITY_CODES=false

SENSITIVE_FIELD_LOGGING_ENABLED=false
REQUEST_BODY_LOGGING_ENABLED=false
DATABASE_CREDENTIAL_LOGGING_ENABLED=false

PERSONAL_DATA_RETENTION_DAYS=90
ANALYTICS_RETENTION_DAYS=365
FEEDBACK_RETENTION_DAYS=365


# ============================================================
# SECTION 13 - FEEDBACK AND CONTROLLED LEARNING
# ============================================================

FEEDBACK_ENABLED=true
FEEDBACK_REVIEW_REQUIRED=true
FEEDBACK_AUTOMATIC_APPROVAL=false

FEEDBACK_EXPECTED_ANSWER_ENABLED=true
FEEDBACK_RATING_ENABLED=true

LEARNING_OBSERVATION_ENABLED=true
LEARNING_REVIEW_QUEUE_ENABLED=true
LEARNING_PROMOTION_ENABLED=true
LEARNING_ROLLBACK_ENABLED=true

MINIMUM_PROMOTION_REVIEWERS=1
MINIMUM_PROMOTION_CONFIDENCE=0.90


# ============================================================
# SECTION 14 - HUMAN HANDOFF
# ============================================================

HUMAN_HANDOFF_ENABLED=true
HUMAN_HANDOFF_FORM_ENABLED=true
HUMAN_HANDOFF_EMAIL_ENABLED=false

HUMAN_HANDOFF_EMAIL_ADDRESS=
HUMAN_HANDOFF_PHONE_NUMBER=

COMPLAINT_HANDOFF_REQUIRED=true
LOW_CONFIDENCE_HANDOFF_AVAILABLE=true


# ============================================================
# SECTION 15 - PRIVATE EVENTS
# ============================================================

PRIVATE_EVENTS_ENABLED=true
PRIVATE_EVENT_DRAFT_PERSISTENCE_ENABLED=true
PRIVATE_EVENT_REVIEW_REQUIRED=true

PRIVATE_EVENT_MINIMUM_GUEST_COUNT=1
PRIVATE_EVENT_MAXIMUM_GUEST_COUNT=1000

PRIVATE_EVENT_REQUIRED_FIELDS=event_type,date,guest_count,email

PRIVATE_EVENT_AVAILABILITY_LIVE_LOOKUP_ENABLED=false
PRIVATE_EVENT_AUTOMATIC_BOOKING_ENABLED=false
PRIVATE_EVENT_AUTOMATIC_PRICE_QUOTE_ENABLED=false


# ============================================================
# SECTION 16 - ANALYTICS
# ============================================================

ANALYTICS_ENABLED=true
ANALYTICS_STORE_PAGE_CONTEXT=true
ANALYTICS_STORE_INTENT=true
ANALYTICS_STORE_CONFIDENCE=true

ANALYTICS_STORE_RAW_MESSAGE=false
ANALYTICS_STORE_EMAIL=false
ANALYTICS_STORE_PHONE=false

ANALYTICS_SAMPLE_RATE=1.0


# ============================================================
# SECTION 17 - RATE LIMITING
# ============================================================

RATE_LIMITING_ENABLED=true

RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_MESSAGES_PER_HOUR=300
RATE_LIMIT_FEEDBACK_PER_HOUR=25
RATE_LIMIT_WIDGET_UPDATES_PER_MINUTE=120

RATE_LIMIT_TRUST_PROXY_HEADERS=true


# ============================================================
# SECTION 18 - HEALTH AND READINESS
# ============================================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
READINESS_CHECK_PATH=/ready

HEALTH_CHECK_INCLUDE_DATABASE=true
HEALTH_CHECK_INCLUDE_STATIC_ASSETS=true
HEALTH_CHECK_EXPOSE_INTERNAL_ERRORS=false


# ============================================================
# SECTION 19 - SOURCE FETCHING
# ============================================================

SOURCE_FETCHING_ENABLED=false
SOURCE_FETCH_TIMEOUT_SECONDS=20
SOURCE_FETCH_MAXIMUM_RETRIES=3
SOURCE_FETCH_CACHE_TTL_SECONDS=3600

OFFICIAL_SOURCE_DOMAIN_ALLOWLIST=thehorseshoetavern.com,www.thehorseshoetavern.com


# ============================================================
# SECTION 20 - EMAIL
# ============================================================

EMAIL_ENABLED=false
EMAIL_PROVIDER=disabled

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

EMAIL_FROM_NAME=Horseshoe Tavern AI
EMAIL_FROM_ADDRESS=


# ============================================================
# SECTION 21 - OPTIONAL EXTERNAL AI
# ============================================================

EXTERNAL_AI_ENABLED=false
EXTERNAL_AI_PROVIDER=disabled
EXTERNAL_AI_MODEL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

EXTERNAL_AI_TIMEOUT_SECONDS=30
EXTERNAL_AI_MAXIMUM_RETRIES=2

EXTERNAL_AI_CAN_OVERRIDE_VERIFIED_FACTS=false
EXTERNAL_AI_CAN_PROMOTE_KNOWLEDGE=false


# ============================================================
# SECTION 22 - DEVELOPMENT AND TESTING
# ============================================================

TESTING=false
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

CREATE_DEMO_DATA=false
ALLOW_TEST_ENDPOINTS=false

ENABLE_API_DOCUMENTATION=true
ENABLE_WIDGET_PREVIEW=true

PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
