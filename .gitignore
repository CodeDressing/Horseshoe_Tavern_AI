# ============================================================
# Exact file location: .gitignore
# Horseshoe Tavern AI
# Phase 1 Part 1.25
# Python, environment, database, IDE, logs, cache, test,
# deployment, temporary, secret, and operating-system exclusions
# ============================================================


# ============================================================
# SECTION 01 - ENVIRONMENT AND SECRETS
# ============================================================

.env
.env.*
!.env.example

*.env
*.env.local
*.env.development
*.env.production
*.env.test

secrets/
secret/
private/
credentials/
credential/

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore

service-account*.json
credentials*.json
oauth*.json
client-secret*.json
client_secret*.json

.npmrc
.pypirc
.netrc

# Keep safe templates
!.env.example


