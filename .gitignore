# ============================================================
# SECTION 29 - LOCK FILE POLICY
# ============================================================

# Keep dependency lock files when intentionally created.
# Do not ignore:
# requirements.txt
# requirements.lock
# poetry.lock
# uv.lock
# Pipfile.lock
# package-lock.json
# pnpm-lock.yaml
# yarn.lock


# ============================================================
# SECTION 30 - REQUIRED PROJECT FILES THAT MUST REMAIN TRACKABLE
# ============================================================

!.gitignore
!.env.example
!requirements.txt
!render.yaml

!app/
!app/**

# Local secrets and generated data remain ignored by the earlier rules.
